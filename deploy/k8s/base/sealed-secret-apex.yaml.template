# ─── APEX SealedSecret Template ──────────────────────────────────────────────
#
# DO NOT commit this file with real `encryptedData` values generated against
# a production cluster.  Commit the *template* only; generate the actual
# sealed values per-cluster using `scripts/seal_secret.sh`.
#
# Prerequisite: kubeseal CLI installed + sealed-secrets-controller running:
#   ./scripts/seal_secret.sh bootstrap
#
# To generate sealed values for a fresh cluster:
#   ./scripts/seal_secret.sh seal-all
#
# The generated `deploy/k8s/base/sealed-secret-apex-generated.yaml` should then
# be committed to your private config repo (encrypted values are safe to commit).
# ──────────────────────────────────────────────────────────────────────────────
---
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: apex-alpaca-secret
  namespace: apex
  annotations:
    # sealing-scope: namespace-wide — can only be unsealed in the apex namespace
    sealedsecrets.bitnami.com/namespace-wide: "true"
spec:
  encryptedData:
    # REPLACE THESE with values from: ./scripts/seal_secret.sh seal-all
    api_key: REPLACE_WITH_KUBESEAL_OUTPUT__ALPACA_API_KEY
    secret_key: REPLACE_WITH_KUBESEAL_OUTPUT__ALPACA_SECRET_KEY
  template:
    metadata:
      name: apex-alpaca-secret
      namespace: apex
    type: Opaque

---
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: apex-db-secret
  namespace: apex
  annotations:
    sealedsecrets.bitnami.com/namespace-wide: "true"
spec:
  encryptedData:
    # REPLACE with: ./scripts/seal_secret.sh seal-all
    username: REPLACE_WITH_KUBESEAL_OUTPUT__POSTGRES_USER
    password: REPLACE_WITH_KUBESEAL_OUTPUT__POSTGRES_PASSWORD
  template:
    metadata:
      name: apex-db-secret
      namespace: apex
    type: Opaque

---
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: apex-api-secret
  namespace: apex
  annotations:
    sealedsecrets.bitnami.com/namespace-wide: "true"
spec:
  encryptedData:
    # REPLACE with: ./scripts/seal_secret.sh seal-all
    anthropic_api_key: REPLACE_WITH_KUBESEAL_OUTPUT__ANTHROPIC_API_KEY
    polygon_api_key: REPLACE_WITH_KUBESEAL_OUTPUT__POLYGON_API_KEY
  template:
    metadata:
      name: apex-api-secret
      namespace: apex
    type: Opaque

---
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: apex-redis-secret
  namespace: apex
  annotations:
    sealedsecrets.bitnami.com/namespace-wide: "true"
spec:
  encryptedData:
    # REPLACE with: ./scripts/seal_secret.sh seal-all
    # Leave empty string if Redis is unauthenticated (dev only)
    password: REPLACE_WITH_KUBESEAL_OUTPUT__REDIS_PASSWORD
  template:
    metadata:
      name: apex-redis-secret
      namespace: apex
    type: Opaque
